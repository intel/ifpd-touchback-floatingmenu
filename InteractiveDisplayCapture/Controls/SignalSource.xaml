                         Direction="90"/>

            </Border.Effect>
            <StackPanel Margin="20">

                <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center" 
                        Margin="0,0,0,5">
                    <Path Height="28"
                  Width="28" 
                  Stretch="Uniform" 
                  Fill="White" 
                  Data="M3.5 4V0.5H11.5V4M5 2.5H6M9 2.5H10M5.5 13V15M9.5 13V15M2.5 4.5H12.5V9.5L10.5 10.5V12.5H4.5V10.5L2.5 9.5V4.5Z"/>
                    <TextBlock Text="Signal Source"
                       FontSize="22"
                       Foreground="White"
                       FontWeight="Bold"
                       Margin="10,0,0,10"/>
                </StackPanel>

                <Separator Margin="0,0,0,10" Background="White"/>

                <!-- Device List -->
                <ListBox x:Name="DeviceList"
                    ItemsSource="{Binding Devices}"
                    PreviewMouseLeftButtonUp="DeviceList_PreviewMouseLeftButtonUp"
                     ItemContainerStyle="{StaticResource DeviceListBoxItemStyle}"
                     ItemTemplate="{StaticResource DeviceItemTemplate}"
                     Background="Transparent"
                     BorderThickness="0"/>

                <Image x:Name="CameraImage"
       Stretch="Uniform"
       HorizontalAlignment="Stretch"
       VerticalAlignment="Stretch"/>
