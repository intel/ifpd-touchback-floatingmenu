<Page x:Class="InteractiveDisplayCapture.Controls.SignalSource"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:InteractiveDisplayCapture.Controls"
      mc:Ignorable="d" 
      Background="Transparent"
      Title="SignalSource" 
      Width="270"
      Height="280">
    <Page.Resources>

        <Style x:Key="SignalSourceCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Padding" Value="20"/>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="25"
                              ShadowDepth="6"
                              Opacity="0.25"
                              Direction="90"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeviceListBoxItemStyle" TargetType="ListBoxItem">

            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>

            <!-- Custom Template -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                        Background="Transparent"
                        CornerRadius="10"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                        Padding="15,0,15,0"
                                Margin="0,0,0,12">

                            <ContentPresenter/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover Effect -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder"
                                Property="Background"
                                Value="#33FFFFFF"/>
                            </Trigger>

                            <!-- Selected Effect -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder"
                                Property="Background"
                                Value="#55FFFFFF"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- Disable if Disconnected -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Disconnected">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="Opacity" Value="0.5"/>
                </DataTrigger>
            </Style.Triggers>

        </Style>

        <DataTemplate x:Key="DeviceItemTemplate">

            <StackPanel Orientation="Horizontal"
                Margin="0,10"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

                <Border x:Name="Indicator"
                Width="58"
                Height="58"
                CornerRadius="8"
                Background="#9E9E9E">

                    <Path Height="38"
                  Width="38"
                  Stretch="Uniform"
                  Fill="White"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Data="M160-160q-33 0-56.5-23.5T80-240v-120h80v120h640v-480H160v120H80v-120q0-33 23.5-56.5T160-800h640q33 0 56.5 23.5T880-720v480q0 33-23.5 56.5T800-160H160Zm300-140-56-58 83-82H80v-80h407l-83-82 56-58 180 180-180 180Z"/>
                </Border>

                <TextBlock Text="{Binding Name}"
                   Foreground="White"
                   FontSize="26"
                   Margin="20,0,0,0"
                   VerticalAlignment="Center"/>

            </StackPanel>

            <DataTemplate.Triggers>

                <DataTrigger Binding="{Binding Status}" Value="Available">
                    <Setter TargetName="Indicator"
                    Property="Background"
                    Value="#2196F3"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Connected">
                    <Setter TargetName="Indicator"
                    Property="Background"
                    Value="#2E7D32"/>
                </DataTrigger>

            </DataTemplate.Triggers>

        </DataTemplate>


        <!-- Device Indicator Button Style --><!--
        <Style x:Key="DeviceIndicatorStyle" TargetType="Button">

            --><!-- Default --><!--
            <Setter Property="Background" Value="#9E9E9E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Width" Value="58"/>
            <Setter Property="Height" Value="58"/>

            --><!-- Rounded Template --><!--
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            --><!-- Hover Effect --><!--
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                    Property="Opacity"
                                    Value="0.85"/>
                            </Trigger>

                            --><!-- Disabled look --><!--
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border"
                                    Property="Opacity"
                                    Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>

                --><!-- Available --><!--
                <DataTrigger Binding="{Binding}" Value="Available">
                    <Setter Property="Background" Value="Aqua"/>
                    <Setter Property="IsEnabled" Value="True"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </DataTrigger>

                --><!-- Connected --><!--
                <DataTrigger Binding="{Binding}" Value="Connected">
                    <Setter Property="Background" Value="#2E7D32"/>
                    <Setter Property="IsEnabled" Value="True"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </DataTrigger>

                --><!-- Disconnected --><!--
                <DataTrigger Binding="{Binding}" Value="Disconnected">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="Background" Value="#9E9E9E"/>
                </DataTrigger>

            </Style.Triggers>

        </Style>-->
        <!--<Style x:Key="DeviceIndicatorStyle" TargetType="Border">
            <Setter Property="Background" Value="#9E9E9E"/>

            <Style.Triggers>

                --><!-- Connected = Green --><!--
